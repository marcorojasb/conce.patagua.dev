{
  "name": "conce-transporte",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Visor de transporte público de Concepción, Chile",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "sync:biotren": "node --experimental-strip-types --no-warnings --dns-result-order=ipv4first scripts/fetch-biotren.ts",
    "sync:terminals": "node --experimental-strip-types --no-warnings --dns-result-order=ipv4first scripts/fetch-terminals.ts",
    "sync:paraderos": "node --experimental-strip-types --no-warnings --dns-result-order=ipv4first scripts/fetch-paraderos.ts",
    "sync:biotren-track": "node --experimental-strip-types --no-warnings --dns-result-order=ipv4first scripts/fetch-biotren-track.ts",
    "sync:gtfs-concepcion": "node --experimental-strip-types --no-warnings scripts/generate-gtfs-concepcion.ts",
    "sync:gtfs-schedule": "node --experimental-strip-types --no-warnings scripts/extract-gtfs-schedule.ts",
    "sync:coverage": "node --experimental-strip-types --no-warnings scripts/extract-coverage-grid.ts",
    "sync:stop-frequency": "node --experimental-strip-types --no-warnings scripts/extract-stop-frequency.ts",
    "sync:pois": "node --experimental-strip-types --no-warnings --dns-result-order=ipv4first scripts/fetch-pois.ts",
    "sync:wikidata": "node --experimental-strip-types --no-warnings --dns-result-order=ipv4first scripts/fetch-wikidata.ts",
    "sync:cycleways": "node --experimental-strip-types --no-warnings --dns-result-order=ipv4first scripts/fetch-cycleways.ts",
    "sync:all": "npm run sync:biotren && npm run sync:terminals && npm run sync:paraderos && npm run sync:biotren-track && npm run sync:gtfs-concepcion && npm run sync:pois && npm run sync:wikidata && npm run sync:cycleways"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.16",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
